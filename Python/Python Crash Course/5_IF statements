'''CHECKING MULTIPLE CONDITIONS'''

# Keywords 'and' and 'or' can be helpful to check multiple conditions to be True to take an action.

''' Using 'AND' to check multiple conditions '''

age_0 = 22
age_1 = 18
age_0 >= 21 and age_1 >= 21     # True and False --> False

age_1 = 22
age_0 >= 21 and age_1 >= 21     # True and True --> True

# To improve readability, we can use parentheses around the individual tests, but they are not required.
(age_0 >= 21) and (age_1 >= 21)     # True and True --> True

''' Using 'OR' to check multiple conditions '''

# An or expression fails only when both individuals tests fail.

age_0 = 22
age_1 = 18
age_0 >= 21 or age_1 >= 21     # True or False --> True

age_0 = 18
age_0 >= 21 or age_1 >= 21     # False or False --> False


