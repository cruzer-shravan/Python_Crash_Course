'''WORKING WITH PART OF A LIST'''

# SLICING A LIST

players = ['charles', 'martina', 'michael', 'adam', 'eli']
print(players[0:3])
print(players[1:4])

print(players[:4])  # beginning of a list
print(players[2:])  # upto end of a list

print(players[-3:]) # Negative index [-3:-1] i.e. last three players

# We can include third value in the brackets indicating a slice.
# Third value decides number of items to skip between items in the specified range.


'''LOOPING THROUGH A SLICE'''

print("Here are the last three players in my team")
for player in players[-3:]:
    print(f"\t{player.title()}")

'''COPYING A LIST'''

my_foods = ['rice', 'dal', 'paneer', 'curd']
print(f"My foods are: {my_foods}")

friends_food = my_foods[:]
print(f"My friend foods are: {friends_food}")

my_foods.append('milk')
friends_food.append('soya chunks')

print(f"My foods are addition: {my_foods}")
print(f"My friend foods are addition: {friends_food}")