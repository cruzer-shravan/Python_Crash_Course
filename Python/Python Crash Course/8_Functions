'''PASSING ARGUMENTS'''

''' POSITIONAL ARGUMENTS '''
# Positional arguments need to be in the same order the parameters were written. Order matters.

def describe_pet(animal_type, pet_name):
    """Displays information about pet"""
    print(f"\nI have a {animal_type.title()}.")
    print(f"My {animal_type.title()}'s name is {pet_name.title()}.")

describe_pet('hamster', 'harry')    

# Argument 'hamster' is assigned to the parameter animal_type and 'harry' to pet_name.

''' MULTIPLE FUNCTION CALLS'''

# Calling a function multiple times is a very efficient way to work.

describe_pet('german shepherd', 'rocky')
describe_pet('pitbull', 'puppy')


'''KEYWORD ARGUMENTS'''

# A Keyword argument is a name-value pair that you pass to a function.
# We directly associate the name and the value within the argument, thereby avoiding confusion.

describe_pet(animal_type='labrador', pet_name='larry')
describe_pet(animal_type='boxer', pet_name='tyson')
describe_pet(animal_type='pug', pet_name='pugsy')


'''DEFAULT VALUES'''

# When writing a function, you can define a 'default value' for each parameter.
# If an argument for a parameter is provided in the function call, Python uses the argument value.
# If not it uses the parameter's default value.

def describe_pet(pet_name, animal_type = 'dog'):       # Python interprets this as a positional argument
    """Display's information about pet."""
    print(f"\nI have a {animal_type}.")
    print(f"My {animal_type}'s name is {pet_name.title()}.")

describe_pet('willie')

# If we give an explicit argument for animal_type, pyton ignores the parameter's default value.
describe_pet(animal_type='doberman', pet_name='duffy')

'''NOTE: 
When you use default values, 
any parameter with a default value needs to be listed after all the parameters that don’t have default values. 
This allows Python to continue interpreting positional arguments correctly.'''

'''EQUIVALENT FUNCTION CALLS'''

# There are several equivalent ways to call a function.

# A dog named willie.
describe_pet('willie')
describe_pet(pet_name='willie')

# A hamster named Harry.
describe_pet('harry', 'hamster')
describe_pet(pet_name='harry', animal_type='hamster')
describe_pet(animal_type='hamster', pet_name='harry')


