# 8.3.  T-shirt

def make_shirt(size, message):
    """Describes the size and message to be printed on the T-shirt."""
    print(f"\nI would prefer {size} size T-shirt.")
    print(f"I want '{message.title()}' to be printed on my T-shirt.")

