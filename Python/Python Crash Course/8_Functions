'''RETURN VALUES'''

# Return values allow you to move much of your program's grunt work into functions,
# which can simplify the body of your program.
# The value the function returns is called 'return values'

'RETURNING A SIMPLE VALUE'

# Neatly formatted full name

def get_formatted_name(first_name, last_name):
    """Returns a full name, neatly formatted. Useful when working with large programs."""
    full_name = f"\n{first_name} {last_name}"
    return full_name.title()        # This line is returned to the calling line. 

musician = get_formatted_name('jimi', 'hendrix')    # calling line
print(musician)


'''MAKING AN ARGUMENT OPTIONAL'''

def get_formatted_name(first_name, middle_name, last_name):
    """Returns a full name, neatly formatted. Useful when working with large programs."""
    full_name = f"\n{first_name} {middle_name} {last_name}"
    return full_name.title()        # This line is returned to the calling line. 

musician = get_formatted_name('amit', 'kumar', 'singh')    # calling line
print(musician)


# MAKING ARGUMENT OPTIONAL

def get_formatted_name(first_name, last_name, middle_name = ""):
    """Returns a full name, neatly formatted. Useful when working with large programs."""
    if middle_name:
        full_name = f"\n{first_name} {middle_name} {last_name}"
    else:
        full_name = f"\n{first_name} {last_name}"
    return full_name.title()        # This line is returned to the calling line. 

musician = get_formatted_name('jai', 'krishn', 'shri')    # calling line
print(musician)

musician = get_formatted_name('jai', 'hanuman')
print(musician)