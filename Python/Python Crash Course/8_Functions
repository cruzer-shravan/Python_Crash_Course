# Functions are named blocks of code designed to do one specific job.
# Using functions makes your programs easier to write, read, test and fix.

# Certain functions - primary job is to display information and other functions.
# Other functions - designed to process data and return a value or set of values.

# Functions are stored in separate files called Modules to help organize your main program files.


'''SIMPLE FUNCTION'''

def greet_user():                       # keyword
    """Display a simple greeting."""    # docstring - describes what the function does.
    print("Hello!")                     # actual code

greet_user()                            # call function - executes the code in the function


'''Passing information to a Function'''

def greet_user(username):                   # username - parameter i.e variable
    """Display a simple greeting"""
    print(f"Hello! {username.title()}.")

greet_user('mike')                          # mike - argument i.e. value (value is assigned to parameter)



