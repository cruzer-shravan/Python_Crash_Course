# Looping through favourite languages

favourite_languages1 = {
    'jen': 'python',
    'sam': 'c',
    'james': 'java',
    'mike': 'python'
}

for name, language in favourite_languages1.items(): print(f"{name.title()}'s favourite language is {language.title()}")

# Looping through all the keys in a dictionary
for name in favourite_languages1.keys():    # key() method is used to work with only keys
    print(name.title())

# OR

for name in favourite_languages1:
    print(name.title())


friends = ['sam', 'mike']
for name in favourite_languages1:
    print(f"Hi, {name.title()}.")
    
    if name in friends:
        language = favourite_languages1[name].title()
        print(f"\t{name.title()}, I see you love {language}!")    # Friends receive a special message


# Check 'not in' in dictionary

if 'edward' not in favourite_languages1.keys():
    print('Edward, please take our poll!')

# If statement simply checks if 'edward' is in this sequence.
# since he's not in the dictionary, a message is printed inviting him to take the poll!


'''LOOPING THROUGH A DICTIONARY'S KEYS IN A PARTICULAR ORDER'''

# sorted() function

for name in sorted(favourite_languages1.keys()):
    print(f"{name.title()}, thank you for taking the poll!")


'''Looping through all VALUES in a dictionary '''

print(f"\nThe following languages have been mentioned:")
for language in favourite_languages1.values():      # prints all the values though duplicacy exists
    print(language.title())

print(f"\nThe following languages have been mentioned:")
for language in set(favourite_languages1.values()):     # A set is a collection in which each item must be unique.
    print(language.title())

# NOTE: You can build a set directly using braces and separating the elements with commas

languages = {'python', 'java', 'rust', 'python', 'c++'}
print(languages)    # prints only unique set of elements

'''
NOTE: It’s easy to mistake sets for dictionaries because they’re both wrapped in braces. 
When you see braces but no key-value pairs, you’re probably looking at a set.
Unlike lists and dictionaries, sets do not retain items in any specific order.
'''