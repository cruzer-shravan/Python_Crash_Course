'''NESTING'''

# Nesting is a powerful feature, which can store multiple dictionaries in a list,
# or a list of items as a value in a dictionary.

'A list of Dictionaries'

#1 Dictionaries in a list - list of multiple aliens

alien_0 = {'color': 'green', 'points': 5}
alien_1 = {'color': 'yellow', 'points': 10}
alien_2 = {'color': 'red', 'points': 15}

aliens = [alien_0, alien_1, alien_2]
for alien in aliens:
    print(alien)


#2 Realistic example - use range() to create a fleet of 30 aliens

# Make an empty list for storing aliens.
aliens1=[]

# Make 30 green aliens
for alien_number in range(30):
    new_alien =  {'color': 'green', 'points': 5, 'speed': 'slow'}
    aliens1.append(new_alien)

# Show the first 5 aliens
for alien in aliens1[:5]:
    print(alien)
print("..........")

# show how many aliens have been created
print(f"The total number of aliens are {len(aliens1)}")


#3 Changing the first three aliens to yellow, medium-speed aliens worth 10 points each.

# Make an empty list for storing aliens.
aliens2=[]

# Make 30 green aliens
for alien_number in range(30):
    new_alien =  {'color': 'green', 'points': 5, 'speed': 'slow'}
    aliens2.append(new_alien)

for alien in aliens2[:3]:
    if alien['color'] == 'green':
        alien['color'] = 'yellow'
        alien['speed'] = 'medium'
        alien['points'] = 10
    
# Show the first five aliens
for alien in aliens2[:5]:
    print(alien)
print(".................")

#3  Adding elif block that turns yellow aliens into red
for alien in aliens2[:3]:
    if alien['color'] == 'green':
        alien['color'] = 'yellow'
        alien['speed'] = 'medium'
        alien['points'] = 10
    elif alien['color'] == 'yellow':
        alien['color'] = 'red'
        alien['speed'] = 'fast'
        alien['points'] = 15


